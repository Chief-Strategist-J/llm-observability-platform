# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=quality-engine-group
KAFKA_TOPIC_INPUT=llm.spans.sampled
KAFKA_TOPIC_SCORES=llm.quality.scores
KAFKA_TOPIC_TOXICITY=llm.toxicity.flagged
KAFKA_TOPIC_ALERTS=alerts.quality.degradation

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quality_engine_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=quality-engine-tasks

# Embedding Worker
EMBEDDING_WORKER_URL=http://localhost:8001

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Consumer
CONSUMER_CONCURRENCY=4
