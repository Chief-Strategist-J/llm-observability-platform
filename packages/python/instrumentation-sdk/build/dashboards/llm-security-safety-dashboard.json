{
  "uid": "llm-security-safety-dashboard",
  "title": "LLM Security & Safety Dashboard",
  "tags": ["llm", "security", "pii", "injection", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "PII Detection Rate (per 5m)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llm_pii_detected_total[5m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Prompt Injection Attempts Rate (per 5m)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llm_injection_attempts_total[5m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total PII Detections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(llm_pii_detected_total)",
          "legendFormat": "PII Detected",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Injection Attempts",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(llm_injection_attempts_total)",
          "legendFormat": "Injection Attempts",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Security Violations (PII + Injections)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(llm_pii_detected_total) + sum(llm_injection_attempts_total)",
          "legendFormat": "Total Violations",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Security Events Over Time (PII + Injections)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(llm_pii_detected_total[5m])) by (service_name)",
          "legendFormat": "PII — {{service_name}}",
          "refId": "A"
        },
        {
          "expr": "sum(increase(llm_injection_attempts_total[5m])) by (service_name)",
          "legendFormat": "Injection — {{service_name}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Security Events by Service",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum(llm_pii_detected_total + llm_injection_attempts_total) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Security Events by Model",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum(llm_pii_detected_total + llm_injection_attempts_total) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ]
}
