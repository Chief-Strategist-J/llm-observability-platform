{
  "uid": "llm-guardrails-dashboard",
  "title": "LLM Guardrails & Invariant Violations",
  "tags": ["llm", "guardrails", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Invariant Breaches (INV-Q-01 to INV-Q-07)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(invariant_violation_total[5m])) by (invariant_id)",
          "legendFormat": "{{invariant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Human Review Queue - SLO (% Reviewed within 24 hours)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "value": null, "color": "red" },
            { "value": 90, "color": "orange" },
            { "value": 95, "color": "green" }
          ]
        }
      },
      "targets": [
        {
          "expr": "quality_review_slo_ratio * 100",
          "legendFormat": "SLO % within 24h",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Human Review Decisions (Confirmed vs False Positives)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum(increase(quality_review_decisions_total[1h])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Content Filter & PII Injection Blocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(llm_security_violations_total[5m])) by (rule_id)",
          "legendFormat": "{{rule_id}}",
          "refId": "A"
        }
      ]
    }
  ]
}
