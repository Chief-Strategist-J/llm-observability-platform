{
  "uid": "llm-quality-engine-dashboard",
  "title": "LLM Quality Engine Dashboard",
  "tags": ["llm", "quality", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Quality Spans Processed Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(quality_spans_processed_total[5m])) by (model, endpoint)",
          "legendFormat": "{{model}} / {{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average Pipeline Evaluation Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(quality_pipeline_latency_ms_sum[5m])) / sum(rate(quality_pipeline_latency_ms_count[5m]))",
          "legendFormat": "Average Latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Invariant Violations Count (per Invariant)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(invariant_violation_total[5m])) by (invariant_id)",
          "legendFormat": "{{invariant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Toxic Spans Flagged (Toxicity > 0.50)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum(quality_toxic_flagged_total) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Embedding Cache Reuse Metrics",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum(quality_embedding_reuse_total) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
