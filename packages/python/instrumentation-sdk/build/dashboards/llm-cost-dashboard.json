{
  "uid": "llm-cost-dashboard",
  "title": "LLM Cost Dashboard",
  "tags": ["llm", "cost", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Cumulative Cost Over Time (USD)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(llm_cost_usd_micro_total[5m])) by (service_name, model) / 1000000",
          "legendFormat": "{{service_name}} / {{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Cost Distribution by Model",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum(llm_cost_usd_micro_total) by (model) / 1000000",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cost Distribution by Service",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "sum(llm_cost_usd_micro_total) by (service_name) / 1000000",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM Cost Forecast (USD)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(llm_forecast_cost_mean_usd_micro) by (service_name, model) / 1000000",
          "legendFormat": "Mean - {{service_name}} / {{model}}",
          "refId": "A"
        },
        {
          "expr": "sum(llm_forecast_cost_p10_usd_micro) by (service_name, model) / 1000000",
          "legendFormat": "p10 - {{service_name}} / {{model}}",
          "refId": "B"
        },
        {
          "expr": "sum(llm_forecast_cost_p90_usd_micro) by (service_name, model) / 1000000",
          "legendFormat": "p90 - {{service_name}} / {{model}}",
          "refId": "C"
        }
      ]
    }
  ]
}
