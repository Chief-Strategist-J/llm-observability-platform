{
  "uid": "llm-forecast-dashboard",
  "title": "LLM Cost Forecast Dashboard",
  "tags": ["llm", "forecast", "cost", "timesfm", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Forecasted Cost — Mean with Confidence Band (USD)",
      "type": "timeseries",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*p10.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "semi-dark-green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*p90.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*Mean.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(llm_forecast_cost_mean_usd_micro) by (service_name, model) / 1000000",
          "legendFormat": "Mean — {{service_name}} / {{model}}",
          "refId": "A"
        },
        {
          "expr": "sum(llm_forecast_cost_p10_usd_micro) by (service_name, model) / 1000000",
          "legendFormat": "p10 (optimistic) — {{service_name}} / {{model}}",
          "refId": "B"
        },
        {
          "expr": "sum(llm_forecast_cost_p90_usd_micro) by (service_name, model) / 1000000",
          "legendFormat": "p90 (pessimistic) — {{service_name}} / {{model}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "Forecast Mean (Current) by Model",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.02 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "sum(llm_forecast_cost_mean_usd_micro) by (model) / 1000000",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Forecast Uncertainty Band Width (p90 - p10)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(llm_forecast_cost_p90_usd_micro) by (model) - sum(llm_forecast_cost_p10_usd_micro) by (model)) / 1000000",
          "legendFormat": "Uncertainty — {{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Forecast vs Actual Cost (Mean)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Actual Cost" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Forecast Mean" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(increase(llm_cost_usd_micro_total[5m])) by (model) / 1000000",
          "legendFormat": "Actual Cost — {{model}}",
          "refId": "A"
        },
        {
          "expr": "sum(llm_forecast_cost_mean_usd_micro) by (model) / 1000000",
          "legendFormat": "Forecast Mean — {{model}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Current Forecast Values",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.015 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "sum(llm_forecast_cost_mean_usd_micro) / 1000000",
          "legendFormat": "Mean",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "p10 Optimistic Forecast",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(llm_forecast_cost_p10_usd_micro) / 1000000",
          "legendFormat": "p10",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "p90 Pessimistic Forecast",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(llm_forecast_cost_p90_usd_micro) / 1000000",
          "legendFormat": "p90",
          "refId": "A"
        }
      ]
    }
  ]
}
