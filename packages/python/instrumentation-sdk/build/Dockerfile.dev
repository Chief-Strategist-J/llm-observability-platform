FROM python:3.12-slim

WORKDIR /app

# Install system dependencies including git for editable installs
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy only pyproject.toml first to cache dependencies
COPY pyproject.toml .

# Create a dummy src directory so pip install -e . succeeds for dependency caching
RUN mkdir -p src/instrumentation_sdk && touch src/instrumentation_sdk/__init__.py
RUN pip install -e . uvicorn

# Now copy the real source code (this layer will be invalidated on every source change)
COPY src/ src/
RUN pip install -e . --no-deps


# Command to run the API with hot-reload
CMD ["uvicorn", "src.api.rest.v1.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
