# Environment Configuration for kafka-messaging-internal

# Application Settings
APP_NAME=kafka-messaging-internal
APP_VERSION=1.0.0
DEPLOYMENT_ENV=development
HOST_NAME=localhost

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

# Security
SECRET_TOKEN=your-secret-token
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=100

# Database Configuration
# PostgreSQL (primary)
DATABASE_TYPE=postgresql
POSTGRES_DSN=postgresql://user:password@localhost:5432/kafka_events
POSTGRES_MIN_CONNECTIONS=2
POSTGRES_MAX_CONNECTIONS=10

# MongoDB (alternative)
# DATABASE_TYPE=mongodb
# MONGODB_URI=mongodb://localhost:27017/
# MONGODB_DATABASE_NAME=kafka_events

# Schema Registry Configuration
SCHEMA_REGISTRY_URL=http://localhost:8081
SCHEMA_REGISTRY_AUTH_USERNAME=
SCHEMA_REGISTRY_AUTH_PASSWORD=
SCHEMA_REGISTRY_COMPATIBILITY=BACKWARD

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=kafka-messaging-internal
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=kafka-messaging-internal
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=service.name=kafka-messaging-internal,service.version=1.0.0,deployment.env=development

# Redis Configuration (optional - for queue and idempotency)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Testing Configuration
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/kafka_events_test
TEST_SCHEMA_REGISTRY_URL=http://localhost:8081
TEST_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true
