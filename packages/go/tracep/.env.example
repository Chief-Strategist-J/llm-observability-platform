# tracep server environment variables
# Copy to .env and fill in values

# Bearer token used to authenticate both ingest (POST /v1/traces) and query API calls.
# Required — server starts without it but all requests will return 401.
TRACE_TOKEN=

# SQLite database file path (relative or absolute)
DB_PATH=./tracep.db

# Port for the OTLP/HTTP ingest endpoint (POST /v1/traces)
INGEST_PORT=4318

# Port for the Query REST API
QUERY_PORT=4319
