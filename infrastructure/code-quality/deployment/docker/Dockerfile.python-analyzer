# Optimized Dockerfile for Python Deep Analyzer
FROM python:3.11-slim as base

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set up Python environment
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy requirements for better caching
COPY analysis-tools/python/requirements.txt /tmp/requirements.txt

# Install dependencies
RUN pip install --upgrade pip && \
    pip install -r /tmp/requirements.txt

# Working directory
WORKDIR /app

# Copy analyzer code
COPY analysis-tools/python/ .

# Install the analyzer
RUN pip install -e .

# Production stage
FROM base as production

# Create non-root user
RUN useradd --create-home --shell /bin/bash analyzer

# Set ownership
RUN chown -R analyzer:analyzer /app /opt/venv

# Switch to non-root user
USER analyzer

# Add analyzer to PATH
ENV PATH="/app:$PATH"

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python deep_analyzer.py --help || exit 1

# Default command
CMD ["python", "deep_analyzer.py", "/code"]

# Development stage
FROM base as development

# Install development tools
RUN pip install pytest pytest-cov black flake8 mypy

# Set up development environment
ENV FLASK_ENV=development

# Default command for development
CMD ["python", "-m", "pytest", "tests/", "-v"]
